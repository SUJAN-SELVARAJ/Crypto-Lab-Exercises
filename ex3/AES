<!DOCTYPE html>
<html>
<head>
<title>AES-128 Enhanced Visualizer</title>
<style>
body{
    font-family: monospace;
    background:#111;
    color:#00ff88;
    padding:20px;
    line-height:1.6;
}
input,button{
    margin:5px;
    padding:6px;
}
#output{
    margin-top:20px;
}
.line{
    margin:4px 0;
}
.matrix{
    display:inline-block;
    margin:10px;
    vertical-align:top;
}
.matrix-row{
    display:block;
}
.matrix-cell{
    display:inline-block;
    width:30px;
    text-align:center;
    margin:2px;
    padding:4px;
    background:#222;
    border:1px solid #444;
}
.highlight{
    background:#004400;
}
.section{
    margin:15px 0;
    padding:10px;
    background:#0a0a0a;
    border-left:3px solid #00ff88;
}
.xor-step{
    font-family:monospace;
    margin:2px 0;
    padding:2px 5px;
    background:#1a1a1a;
}
</style>
</head>

<body>

<h2>AES-128 Enhanced Encryption Visualizer</h2>

Plaintext (32 hex chars): 
<input type="text" id="plaintext" value="00112233445566778899aabbccddeeff" size="40"><br>

Key (32 hex chars): 
<input type="text" id="key" value="000102030405060708090a0b0c0d0e0f" size="40"><br>

Number of Rounds (1-10): 
<input type="number" id="rounds" value="10" min="1" max="10" style="width:60px;"><br>

Speed (ms):
<input type="range" id="speed" min="100" max="3000" value="1000">
<span id="speedVal">1000</span><br>

<button onclick="initialize()">Initialize</button>
<button onclick="play()">Play</button>
<button onclick="pause()">Pause</button>
<button onclick="resume()">Resume</button>
<button onclick="nextStep()">Next</button>
<button onclick="reset()">Reset Display</button>

<div id="output"></div>

<script>

/* ========= CONTROL ========= */

let steps=[];
let index=0;
let playing=false;
let delay=1000;

document.getElementById("speed").oninput=function(){
    delay=this.value;
    document.getElementById("speedVal").innerText=this.value;
};

function addStep(html){ 
    steps.push(html); 
}

function renderStep(){
    if(index<steps.length){
        const d=document.createElement("div");
        d.className="line";
        d.innerHTML=steps[index];
        document.getElementById("output").appendChild(d);
        index++;
        window.scrollTo(0, document.body.scrollHeight);
    }
}

function nextStep(){ renderStep(); }

function play(){
    playing=true;
    autoPlay();
}

function autoPlay(){
    if(!playing) return;
    if(index<steps.length){
        renderStep();
        setTimeout(autoPlay,delay);
    }
}

function pause(){ playing=false; }
function resume(){ playing=true; autoPlay(); }
function reset(){ 
    document.getElementById("output").innerHTML="";
    index=0;
}

/* ========= AES TABLES ========= */

function hexToBytes(hex){
    let bytes=[];
    for(let i=0;i<hex.length;i+=2)
        bytes.push(parseInt(hex.substr(i,2),16));
    return bytes;
}

function bytesToHex(bytes){
    return bytes.map(b=>b.toString(16).padStart(2,'0')).join('');
}

const sbox = [
0x63,0x7c,0x77,0x7b,0xf2,0x6b,0x6f,0xc5,0x30,0x01,0x67,0x2b,0xfe,0xd7,0xab,0x76,
0xca,0x82,0xc9,0x7d,0xfa,0x59,0x47,0xf0,0xad,0xd4,0xa2,0xaf,0x9c,0xa4,0x72,0xc0,
0xb7,0xfd,0x93,0x26,0x36,0x3f,0xf7,0xcc,0x34,0xa5,0xe5,0xf1,0x71,0xd8,0x31,0x15,
0x04,0xc7,0x23,0xc3,0x18,0x96,0x05,0x9a,0x07,0x12,0x80,0xe2,0xeb,0x27,0xb2,0x75,
0x09,0x83,0x2c,0x1a,0x1b,0x6e,0x5a,0xa0,0x52,0x3b,0xd6,0xb3,0x29,0xe3,0x2f,0x84,
0x53,0xd1,0x00,0xed,0x20,0xfc,0xb1,0x5b,0x6a,0xcb,0xbe,0x39,0x4a,0x4c,0x58,0xcf,
0xd0,0xef,0xaa,0xfb,0x43,0x4d,0x33,0x85,0x45,0xf9,0x02,0x7f,0x50,0x3c,0x9f,0xa8,
0x51,0xa3,0x40,0x8f,0x92,0x9d,0x38,0xf5,0xbc,0xb6,0xda,0x21,0x10,0xff,0xf3,0xd2,
0xcd,0x0c,0x13,0xec,0x5f,0x97,0x44,0x17,0xc4,0xa7,0x7e,0x3d,0x64,0x5d,0x19,0x73,
0x60,0x81,0x4f,0xdc,0x22,0x2a,0x90,0x88,0x46,0xee,0xb8,0x14,0xde,0x5e,0x0b,0xdb,
0xe0,0x32,0x3a,0x0a,0x49,0x06,0x24,0x5c,0xc2,0xd3,0xac,0x62,0x91,0x95,0xe4,0x79,
0xe7,0xc8,0x37,0x6d,0x8d,0xd5,0x4e,0xa9,0x6c,0x56,0xf4,0xea,0x65,0x7a,0xae,0x08,
0xba,0x78,0x25,0x2e,0x1c,0xa6,0xb4,0xc6,0xe8,0xdd,0x74,0x1f,0x4b,0xbd,0x8b,0x8a,
0x70,0x3e,0xb5,0x66,0x48,0x03,0xf6,0x0e,0x61,0x35,0x57,0xb9,0x86,0xc1,0x1d,0x9e,
0xe1,0xf8,0x98,0x11,0x69,0xd9,0x8e,0x94,0x9b,0x1e,0x87,0xe9,0xce,0x55,0x28,0xdf,
0x8c,0xa1,0x89,0x0d,0xbf,0xe6,0x42,0x68,0x41,0x99,0x2d,0x0f,0xb0,0x54,0xbb,0x16
];

const rcon = [0x01,0x02,0x04,0x08,0x10,0x20,0x40,0x80,0x1b,0x36];

/* ========= GALOIS FIELD ========= */

function gmul(a, b) {
    let p = 0;
    for (let i = 0; i < 8; i++) {
        if (b & 1) p ^= a;
        let hi_bit_set = a & 0x80;
        a <<= 1;
        if (hi_bit_set) a ^= 0x1b;
        b >>= 1;
    }
    return p & 0xff;
}

/* ========= MATRIX DISPLAY ========= */

function stateToMatrix(state){
    let html = '<div class="matrix"><div class="matrix-row">';
    for(let row=0; row<4; row++){
        for(let col=0; col<4; col++){
            let idx = col*4 + row;
            html += '<span class="matrix-cell">'+state[idx].toString(16).padStart(2,'0')+'</span>';
        }
        html += '</div><div class="matrix-row">';
    }
    html += '</div></div>';
    return html;
}

/* ========= KEY EXPANSION ========= */

function keyExpansion(key, numRounds) {
    let w = [];
    
    // First 4 words are the key itself
    for(let i=0; i<4; i++){
        w[i] = [key[4*i], key[4*i+1], key[4*i+2], key[4*i+3]];
    }
    
    addStep('<div class="section"><b>KEY EXPANSION</b></div>');
    addStep('Initial Key Words:');
    for(let i=0; i<4; i++){
        addStep('w['+i+'] = ['+w[i].map(b=>b.toString(16).padStart(2,'0')).join(', ')+']');
    }
    
    // Generate words needed for specified number of rounds
    let wordsNeeded = 4 * (numRounds + 1);
    
    for(let i=4; i<wordsNeeded; i++){
        let temp = w[i-1].slice();
        
        if(i % 4 === 0){
            addStep('<br>Generating w['+i+']:');
            
            // RotWord
            let rotated = [temp[1], temp[2], temp[3], temp[0]];
            addStep('RotWord(w['+(i-1)+']):  ['+rotated.map(b=>b.toString(16).padStart(2,'0')).join(', ')+']');
            
            // SubWord
            let subbed = rotated.map(b => sbox[b]);
            addStep('SubWord:           ['+subbed.map(b=>b.toString(16).padStart(2,'0')).join(', ')+']');
            
            // XOR with Rcon
            let rconVal = rcon[(i/4)-1];
            subbed[0] ^= rconVal;
            addStep('XOR Rcon['+((i/4)-1)+']={'+rconVal.toString(16)+'}: ['+subbed.map(b=>b.toString(16).padStart(2,'0')).join(', ')+']');
            
            temp = subbed;
        }
        
        // XOR with w[i-4]
        w[i] = [];
        for(let j=0; j<4; j++){
            w[i][j] = w[i-4][j] ^ temp[j];
        }
        
        if(i % 4 === 0 || i < 8){
            addStep('w['+i+'] = w['+(i-4)+'] ⊕ temp = ['+w[i].map(b=>b.toString(16).padStart(2,'0')).join(', ')+']');
        }
    }
    
    // Convert to round keys
    let roundKeys = [];
    for(let round=0; round<=numRounds; round++){
        let rk = [];
        for(let i=0; i<4; i++){
            rk = rk.concat(w[round*4 + i]);
        }
        roundKeys[round] = rk;
    }
    
    addStep('<br><b>Round Keys Generated (for '+numRounds+' rounds):</b>');
    for(let r=0; r<=numRounds; r++){
        addStep('Round '+r+' Key: '+bytesToHex(roundKeys[r]));
    }
    
    return roundKeys;
}

/* ========= XOR VISUALIZATION ========= */

function showXOR(state, roundKey, round){
    addStep('<div class="section"><b>AddRoundKey (Round '+round+') - Bitwise XOR</b></div>');
    
    for(let i=0; i<16; i++){
        let stateBin = state[i].toString(2).padStart(8,'0');
        let keyBin = roundKey[i].toString(2).padStart(8,'0');
        let result = state[i] ^ roundKey[i];
        let resultBin = result.toString(2).padStart(8,'0');
        
        let xorVis = '';
        for(let b=0; b<8; b++){
            xorVis += stateBin[b] + '⊕' + keyBin[b] + '=' + resultBin[b] + '  ';
        }
        
        addStep('<div class="xor-step">Byte['+i+']:  '+
                state[i].toString(16).padStart(2,'0')+' ('+stateBin+') ⊕ '+
                roundKey[i].toString(16).padStart(2,'0')+' ('+keyBin+') = '+
                result.toString(16).padStart(2,'0')+' ('+resultBin+')</div>');
        
        state[i] = result;
    }
    
    addStep('<br><b>State Matrix after AddRoundKey:</b>'+stateToMatrix(state));
    addStep('<b>Round Key Matrix:</b>'+stateToMatrix(roundKey));
    addStep('<b>Hex Result:</b> '+bytesToHex(state));
}

/* ========= MIXCOLUMNS ========= */

function mixColumns(state){
    addStep('<div class="section"><b>MixColumns - Full GF(2⁸) Multiplication</b></div>');
    addStep('Matrix multiplication: [02 03 01 01; 01 02 03 01; 01 01 02 03; 03 01 01 02] × State');
    
    let newState = state.slice();
    
    for(let col=0; col<4; col++){
        let s0 = state[col*4 + 0];
        let s1 = state[col*4 + 1];
        let s2 = state[col*4 + 2];
        let s3 = state[col*4 + 3];
        
        addStep('<br><b>Column '+col+':</b> ['+
                s0.toString(16).padStart(2,'0')+', '+
                s1.toString(16).padStart(2,'0')+', '+
                s2.toString(16).padStart(2,'0')+', '+
                s3.toString(16).padStart(2,'0')+']');
        
        // Row 0
        let r0_1 = gmul(0x02, s0);
        let r0_2 = gmul(0x03, s1);
        let r0_3 = gmul(0x01, s2);
        let r0_4 = gmul(0x01, s3);
        newState[col*4 + 0] = r0_1 ^ r0_2 ^ r0_3 ^ r0_4;
        
        addStep('  Row 0: {02}•'+s0.toString(16).padStart(2,'0')+' ⊕ {03}•'+s1.toString(16).padStart(2,'0')+
                ' ⊕ {01}•'+s2.toString(16).padStart(2,'0')+' ⊕ {01}•'+s3.toString(16).padStart(2,'0'));
        addStep('       = '+r0_1.toString(16).padStart(2,'0')+' ⊕ '+r0_2.toString(16).padStart(2,'0')+
                ' ⊕ '+r0_3.toString(16).padStart(2,'0')+' ⊕ '+r0_4.toString(16).padStart(2,'0')+
                ' = '+newState[col*4 + 0].toString(16).padStart(2,'0'));
        
        // Row 1
        let r1_1 = gmul(0x01, s0);
        let r1_2 = gmul(0x02, s1);
        let r1_3 = gmul(0x03, s2);
        let r1_4 = gmul(0x01, s3);
        newState[col*4 + 1] = r1_1 ^ r1_2 ^ r1_3 ^ r1_4;
        
        addStep('  Row 1: {01}•'+s0.toString(16).padStart(2,'0')+' ⊕ {02}•'+s1.toString(16).padStart(2,'0')+
                ' ⊕ {03}•'+s2.toString(16).padStart(2,'0')+' ⊕ {01}•'+s3.toString(16).padStart(2,'0'));
        addStep('       = '+r1_1.toString(16).padStart(2,'0')+' ⊕ '+r1_2.toString(16).padStart(2,'0')+
                ' ⊕ '+r1_3.toString(16).padStart(2,'0')+' ⊕ '+r1_4.toString(16).padStart(2,'0')+
                ' = '+newState[col*4 + 1].toString(16).padStart(2,'0'));
        
        // Row 2
        let r2_1 = gmul(0x01, s0);
        let r2_2 = gmul(0x01, s1);
        let r2_3 = gmul(0x02, s2);
        let r2_4 = gmul(0x03, s3);
        newState[col*4 + 2] = r2_1 ^ r2_2 ^ r2_3 ^ r2_4;
        
        addStep('  Row 2: {01}•'+s0.toString(16).padStart(2,'0')+' ⊕ {01}•'+s1.toString(16).padStart(2,'0')+
                ' ⊕ {02}•'+s2.toString(16).padStart(2,'0')+' ⊕ {03}•'+s3.toString(16).padStart(2,'0'));
        addStep('       = '+r2_1.toString(16).padStart(2,'0')+' ⊕ '+r2_2.toString(16).padStart(2,'0')+
                ' ⊕ '+r2_3.toString(16).padStart(2,'0')+' ⊕ '+r2_4.toString(16).padStart(2,'0')+
                ' = '+newState[col*4 + 2].toString(16).padStart(2,'0'));
        
        // Row 3
        let r3_1 = gmul(0x03, s0);
        let r3_2 = gmul(0x01, s1);
        let r3_3 = gmul(0x01, s2);
        let r3_4 = gmul(0x02, s3);
        newState[col*4 + 3] = r3_1 ^ r3_2 ^ r3_3 ^ r3_4;
        
        addStep('  Row 3: {03}•'+s0.toString(16).padStart(2,'0')+' ⊕ {01}•'+s1.toString(16).padStart(2,'0')+
                ' ⊕ {01}•'+s2.toString(16).padStart(2,'0')+' ⊕ {02}•'+s3.toString(16).padStart(2,'0'));
        addStep('       = '+r3_1.toString(16).padStart(2,'0')+' ⊕ '+r3_2.toString(16).padStart(2,'0')+
                ' ⊕ '+r3_3.toString(16).padStart(2,'0')+' ⊕ '+r3_4.toString(16).padStart(2,'0')+
                ' = '+newState[col*4 + 3].toString(16).padStart(2,'0'));
    }
    
    for(let i=0; i<16; i++) state[i] = newState[i];
    
    addStep('<br><b>State Matrix after MixColumns:</b>'+stateToMatrix(state));
    addStep('<b>Hex Result:</b> '+bytesToHex(state));
}

/* ========= MAIN AES PROCESS ========= */

function initialize(){

    document.getElementById("output").innerHTML="";
    steps=[]; index=0; playing=false;

    let plaintext = hexToBytes(document.getElementById("plaintext").value);
    let key = hexToBytes(document.getElementById("key").value);
    let numRounds = parseInt(document.getElementById("rounds").value);
    
    // Validate rounds
    if(numRounds < 1 || numRounds > 10){
        alert("Please enter a number of rounds between 1 and 10");
        return;
    }

    let state = plaintext.slice();

    addStep('<div class="section"><h3>AES-128 ENCRYPTION PROCESS ('+numRounds+' Rounds)</h3></div>');
    addStep('<b>Initial Plaintext:</b> ' + bytesToHex(state));
    addStep('<b>Initial State Matrix:</b>'+stateToMatrix(state));
    addStep('<b>Key:</b> ' + bytesToHex(key));
    
    // Key Expansion
    let roundKeys = keyExpansion(key, numRounds);

    /* Round 0 - Initial AddRoundKey */
    addStep('<br><div class="section"><h3>═══════ ROUND 0 (Initial) ═══════</h3></div>');
    showXOR(state, roundKeys[0], 0);

    /* Rounds 1-N */
    for(let round=1; round<=numRounds; round++){

        addStep('<br><div class="section"><h3>═══════ ROUND '+round+' ═══════</h3></div>');

        /* SubBytes */
        addStep('<div class="section"><b>SubBytes (S-Box Substitution)</b></div>');
        addStep('<b>Before SubBytes:</b>'+stateToMatrix(state));
        for(let i=0; i<16; i++){
            let oldVal = state[i];
            state[i] = sbox[state[i]];
            addStep('S-Box['+oldVal.toString(16).padStart(2,'0')+'] = '+state[i].toString(16).padStart(2,'0'));
        }
        addStep('<b>After SubBytes:</b>'+stateToMatrix(state));
        addStep('<b>Hex:</b> '+bytesToHex(state));

        /* ShiftRows */
        addStep('<br><div class="section"><b>ShiftRows</b></div>');
        addStep('<b>Before ShiftRows:</b>'+stateToMatrix(state));
        let temp = state.slice();
        // Row 0: no shift
        // Row 1: shift left by 1
        state[1]=temp[5]; state[5]=temp[9]; state[9]=temp[13]; state[13]=temp[1];
        // Row 2: shift left by 2
        state[2]=temp[10]; state[6]=temp[14]; state[10]=temp[2]; state[14]=temp[6];
        // Row 3: shift left by 3
        state[3]=temp[15]; state[7]=temp[3]; state[11]=temp[7]; state[15]=temp[11];
        addStep('Row 0: No shift');
        addStep('Row 1: Shift left by 1');
        addStep('Row 2: Shift left by 2');
        addStep('Row 3: Shift left by 3');
        addStep('<b>After ShiftRows:</b>'+stateToMatrix(state));
        addStep('<b>Hex:</b> '+bytesToHex(state));

        /* MixColumns (skip in final round) */
        if(round != numRounds){
            addStep('<br>');
            mixColumns(state);
        } else {
            addStep('<br><b>MixColumns:</b> SKIPPED in final round');
        }

        /* AddRoundKey */
        addStep('<br>');
        showXOR(state, roundKeys[round], round);
    }

    addStep('<br><div class="section"><h3>══════════════════════════</h3></div>');
    addStep('<h3 style="color:#00ff00;">FINAL CIPHERTEXT: '+bytesToHex(state)+'</h3>');
    addStep('<b>Final State Matrix:</b>'+stateToMatrix(state));
}

</script>
</body>
</html>
